# Server
PORT=3000
NODE_ENV=development
BACKEND_URL=https://your-domain.com

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback

# JWT
JWT_SECRET=your_very_long_random_secret_here_at_least_64_chars
JWT_EXPIRY=7d

# Database (PostgreSQL via Neon/Supabase or local Docker)
DATABASE_URL=postgresql://otpuser:otppassword@localhost:5432/otpinbox

# Redis (local Docker or Upstash)
REDIS_URL=redis://localhost:6379

# Encryption key for OAuth tokens (must be exactly 32 hex bytes = 64 hex chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_char_hex_encryption_key_here

# Chrome Extension ID (get from chrome://extensions after loading unpacked)
EXTENSION_ID=your_chrome_extension_id_here

# Google Cloud Pub/Sub (Phase 2 - real-time push notifications)
GOOGLE_CLOUD_PROJECT_ID=your_project_id
PUBSUB_TOPIC=gmail-notifications
PUBSUB_SUBSCRIPTION=gmail-push-sub
